# ── Notificaciones (Fase 5) ──────────────────────────────────────────────────
# Email: resumen al finalizar cada run
NOTIFY_EMAIL=tuemail@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuemail@gmail.com
SMTP_PASS=tu-app-password-de-gmail

# Webhook: alerta en tiempo real (Discord / Slack / ntfy.sh)
NOTIFY_WEBHOOK=https://ntfy.sh/tu-canal

# ── Scheduler (Fase 6) ───────────────────────────────────────────────────────
# Portales a correr en modo daemon (separados por coma)
SCHEDULE_PORTALS=linkedin,computrabajo
# Horarios de ejecución diaria (HH:MM, separados por coma)
SCHEDULE_TIMES=09:00,14:00,18:00

# ── Proxy (Fase 8, opcional) ─────────────────────────────────────────────────
# PROXY_URL=http://usuario:password@proxy.host:8080
